rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOwnedUserId(data) {
      return isSignedIn() && data.userId is string && data.userId == request.auth.uid;
    }

    function isFriendshipParticipant(data) {
      return isSignedIn() && data.users is list && data.users.size() == 2 && request.auth.uid in data.users;
    }

    function isGroupMember(members) {
      return isSignedIn() && members is list && request.auth.uid in members;
    }

    match /users/{userId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && request.resource.data.uid == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow read, delete: if hasOwnedUserId(resource.data);
      allow create: if hasOwnedUserId(request.resource.data);
      allow update: if hasOwnedUserId(resource.data) && hasOwnedUserId(request.resource.data);
    }

    match /habits/{habitId} {
      allow read, delete: if hasOwnedUserId(resource.data);
      allow create: if hasOwnedUserId(request.resource.data);
      allow update: if hasOwnedUserId(resource.data) && hasOwnedUserId(request.resource.data);
    }

    match /completions/{completionId} {
      allow read, delete: if hasOwnedUserId(resource.data);
      allow create: if hasOwnedUserId(request.resource.data);
      allow update: if hasOwnedUserId(resource.data) && hasOwnedUserId(request.resource.data);
    }

    match /friendships/{friendshipId} {
      allow read, delete: if isFriendshipParticipant(resource.data);
      allow create: if isFriendshipParticipant(request.resource.data)
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.users[0] != request.resource.data.users[1];
      allow update: if isFriendshipParticipant(resource.data)
        && isFriendshipParticipant(request.resource.data)
        && request.resource.data.users == resource.data.users
        && request.resource.data.requestedBy == resource.data.requestedBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && (
          request.resource.data.status == resource.data.status
          || (
            resource.data.status == 'pending'
            && request.resource.data.status == 'accepted'
            && request.auth.uid != resource.data.requestedBy
          )
        );
    }

    match /groups/{groupId} {
      allow read: if isGroupMember(resource.data.members);
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members is list
        && request.resource.data.members.size() == 1
        && request.resource.data.members[0] == request.auth.uid;
      allow update: if isSignedIn() && (
        (
          isGroupMember(resource.data.members)
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.members == resource.data.members
        )
        || (
          !isGroupMember(resource.data.members)
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
          && request.resource.data.members is list
          && request.resource.data.members.size() == resource.data.members.size() + 1
          && request.resource.data.members.hasAll(resource.data.members)
          && request.auth.uid in request.resource.data.members
        )
      );
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }
  }
}
